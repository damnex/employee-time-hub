# Supabase / Postgres connection string used by the server and Drizzle.
# Copy this file to .env or .env.local and paste your real Supabase URI.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Optional alias if you prefer not to use DATABASE_URL.
# SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Optional explicit SSL mode. Supabase usually works with sslmode=require in DATABASE_URL.
# PGSSLMODE=require
