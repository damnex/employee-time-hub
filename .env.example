# Supabase / Postgres connection string used by the server and Drizzle.
# Copy this file to .env or .env.local and paste your real Supabase URI.
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[YOUR-REGION].pooler.supabase.com:5432/postgres?sslmode=require

# Optional alias if you prefer not to use DATABASE_URL.
# SUPABASE_DB_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-[YOUR-REGION].pooler.supabase.com:5432/postgres?sslmode=require

# Optional explicit SSL mode. Supabase usually works with sslmode=require in DATABASE_URL.
# PGSSLMODE=require

# Optional: allow insecure face fallback capture when the browser does not support FaceDetector.
# Keep this OFF for better biometric accuracy. Turn it ON only for compatibility/demo use.
# If you want to use the Python CCTV face profiles under python-ml/, enable both flags below locally.
# ALLOW_INSECURE_FACE_FALLBACK=false
# VITE_ALLOW_INSECURE_FACE_FALLBACK=false
